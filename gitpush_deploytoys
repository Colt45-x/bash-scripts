#!/bin/bash
# This is my automated deployment tool - add it to your ~/.bashrc

# --- SMART GIT SYNC FUNCTIONS ---

save-bandit() {
    cd ~/projects/bandit-notes
    git status
    echo -n "Bandit commit reason? (e.g. 'Finished Level 10'): "
    read reason
    git add .
    git commit -m "$reason"
    git push
}

# --- INDIVIDUAL SCRIPT SYNC (Surgical Save) ---
save-one() {
    cd ~/projects/bash-scripts
    
    # Check if a filename was provided
    if [ -z "$1" ]; then
        echo "Error: Please specify a filename (e.g., save-one weather)"
        return 1
    fi

    # Check if the file actually exists
    if [ ! -f "$1" ]; then
        echo "Error: File '$1' not found in this folder."
        return 1
    fi

    # Show the changes for just this file so you can remember what you did
    git diff "$1"
    
    echo "--------------------------------"
    echo -n "Commit reason for $1: "
    read reason
    
    git add "$1"
    git commit -m "$reason"
    git push
    echo "Successfully synced $1 to GitHub."
}

