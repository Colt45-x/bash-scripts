# --- DEPLOYMENT SHORTCUT ---
# This copies your lab script to your live bin folder instantly
deploy-script() {
    cp -i ~/projects/bash-scripts/"$1" ~/bin/"$1"
    chmod +x ~/bin/"$1"
    echo "Deployed $1 to ~/bin/ and made it executable."
}

alias reload='source ~/.bashrc && echo "Environment reloaded!"'
